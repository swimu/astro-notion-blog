---
import type { Post } from '../lib/interfaces.ts'
import { Icon } from 'astro-icon/components'

export interface Props {
  post: Post
}

const { post } = Astro.props
---

<button class="like-button" data-slug={post.Slug}>
  <Icon name="mdi:cards-heart-outline" class="icon-outline" />
  <Icon name="mdi:cards-heart" class="icon-filled" />
  <span class="like-count">{post.Like ?? 0}</span>
</button>

<style>
  .like-button {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    margin-top: 1rem;
    background: none;
    border: 1px solid #ddd;
    border-radius: 999px;
    padding: 0.4rem 1rem;
    font-size: 1rem;
    cursor: pointer;
    color: #555;
    transition: background 0.15s, border-color 0.15s, color 0.15s;
  }
  .like-button:hover {
    background: #fff0f0;
    border-color: #f87171;
  }
  .like-button.liked {
    background: #fff0f0;
    border-color: #f87171;
    color: #ef4444;
  }
  .icon-outline,
  .icon-filled {
    width: 1.4rem;
    height: 1.4rem;
  }
  .icon-filled {
    display: none;
  }
  .like-button.liked .icon-outline {
    display: none;
  }
  .like-button.liked .icon-filled {
    display: inline;
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', async () => {
    const button = document.querySelector('.like-button')
    const slug = button.dataset.slug
    const url = `/api/likes.json?slug=${slug}`
    const countEl = button.querySelector('.like-count')

    const res = await fetch(url)
    if (res.ok) {
      const { likes } = await res.json()
      countEl.textContent = likes
    }

    button.addEventListener('click', async () => {
      if (button.disabled) return
      const res = await fetch(url, { method: 'POST' })
      if (res.ok) {
        const { likes } = await res.json()
        countEl.textContent = likes
        button.classList.add('liked')
        button.disabled = true
      }
    })
  })
</script>
